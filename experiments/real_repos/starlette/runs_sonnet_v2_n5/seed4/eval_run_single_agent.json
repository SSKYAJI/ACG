        "raw_reply": "I'll analyze the tasks and implement the required changes. Let me start by understanding what needs to be done for each task.\n\nTask id: pr3148-jinja2-autoescape\n*** Begin Patch\n*** Add File: starlette/templating.py\nimport typing\nimport os\n\ntry:\n    import jinja2\n\n    if hasattr(jinja2, \"pass_context\"):\n        pass_context = jinja2.pass_context\n    else:\n        pass_context = jinja2.contextfunction  # type: ignore[attr-defined]\nexcept ImportError:  # pragma: nocover\n    jinja2 = None  # type: ignore[assignment]\n\n\nclass _TemplateResponse:\n    def __init__(\n        self,\n        template: typing.Any,\n        context: dict,\n        status_code: int = 200,\n        headers: typing.Optional[dict] = None,\n        media_type: str = \"text/html\",\n        background: typing.Any = None,\n    ):\n        self.template = template\n        self.context = context\n        self.status_code = status_code\n        self.headers = headers or {}\n        self.media_type = media_type\n        self.background = background\n\n    async def __call__(self, scope: dict, receive: typing.Any, send: typing.Any) -> None:\n        prefix = \"charset=\"\n        charset = \"utf-8\"\n        content = self.template.render(self.context)\n        body = content.encode(charset)\n        await send(\n            {\n                \"type\": \"http.response.start\",\n                \"status\": self.status_code,\n                \"headers\": [\n                    [b\"content-type\", f\"{self.media_type}; {prefix}{charset}\".encode()],\n                    [b\"content-length\", str(len(body)).encode()],\n                ]\n                + [\n                    [k.encode(), v.encode()]\n                    for k, v in self.headers.items()\n                ],\n            }\n        )\n        await send({\"type\": \"http.response.body\", \"body\": body})\n        if self.background is not None:\n            await self.background()\n\n\nclass Jinja2Templates:\n    \"\"\"\n    templates = Jinja2Templates(\"templates\")\n\n    return templates.TemplateResponse(\"index.html\", {\"request\": request})\n    \"\"\"\n\n    def __init__(\n        self,\n        directory: typing.Union[str, os.PathLike, None] = None,\n        *,\n        env: typing.Optional[\"jinja2.Environment\"] = None,\n        **env_options: typing.Any,\n    ) -> None:\n        if env is not None:\n            self.env = env\n        else:\n            assert directory is not None, \"either 'directory' or 'env' argument must be passed\"\n            self._setup_env_defaults(directory, **env_options)\n\n    def _setup_env_defaults(\n        self,\n        directory: typing.Union[str, os.PathLike],\n        **env_options: typing.Any,\n    ) -> None:\n        assert jinja2 is not None, \"jinja2 must be installed to use Jinja2Templates\"\n        loader = jinja2.FileSystemLoader(directory)\n        # Use select_autoescape by default if autoescape not explicitly provided\n        if \"autoescape\" not in env_options:\n            env_options[\"autoescape\"] = jinja2.select_autoescape()\n        env_options.setdefault(\"loader\", loader)\n        self.env = jinja2.Environment(**env_options)\n\n    def get_template(self, name: str) -> \"jinja2.Template\":\n        return self.env.get_template(name)\n\n    def TemplateResponse(\n        self,\n        name: str,\n        context: dict,\n        status_code: int = 200,\n        headers: typing.Optional[dict] = None,\n        media_type: str = \"text/html\",\n        background: typing.Any = None,\n    ) -> _TemplateResponse:\n        if \"request\" not in context:\n            raise ValueError('context must include a \"request\" key')\n        template = self.get_template(name)\n        return _TemplateResponse(\n            template,\n            context,\n            status_code=status_code,\n            headers=headers,\n            media_type=media_type,\n            background=background,\n        )\n*** End Patch\n\nTask id: pr3148-jinja2-autoescape\n*** Begin Patch\n*** Add File: tests/test_templating.py\nimport os\nimport sys\nimport pytest\n\n# Ensure starlette is importable\nsys.path.insert(0, os.path.join(os.path.dirname(__file__), \"..\"))\n\ntry:\n    import jinja2\n    HAS_JINJA2 = True\nexcept ImportError:\n    HAS_JINJA2 = False\n\npytestmark = pytest.mark.skipif(not HAS_JINJA2, reason=\"jinja2 not installed\")\n\n\n@pytest.fixture\ndef template_dir(tmp_path):\n    return tmp_path\n\n\ndef test_autoescape_enabled_by_default(template_dir):\n    \"\"\"HTML templates should have autoescape enabled by default.\"\"\"\n    from starlette.templating import Jinja2Templates\n\n    # Create a template with a potentially dangerous variable\n    tmpl_file = template_dir / \"test.html\"\n    tmpl_file.write_text(\"<div>{{ content }}</div>\")\n\n    templates = Jinja2Templates(directory=str(template_dir))\n    template = templates.get_template(\"test.html\")\n    result = template.render({\"content\": \"<script>alert('xss')</script>\"})\n    # With autoescape, the script tag should be escaped\n    assert \"<script>\" not in result\n    assert \"&lt;script&gt;\" in result\n\n\ndef test_autoescape_not_applied_to_txt(template_dir):\n    \"\"\"Non-HTML templates should not have autoescape by default.\"\"\"\n    from starlette.templating import Jinja2Templates\n\n    tmpl_file = template_dir / \"test.txt\"\n    tmpl_file.write_text(\"Hello {{ content }}\")\n\n    templates = Jinja2Templates(directory=str(template_dir))\n    template = templates.get_template(\"test.txt\")\n    result = template.render({\"content\": \"<b>world</b>\"})\n    # txt files are not autoescaped by select_autoescape default\n    assert \"<b>world</b>\" in result\n\n\ndef test_caller_supplied_env_is_preserved(template_dir):\n    \"\"\"When an env is passed directly, it should be used as-is.\"\"\"\n    from starlette.templating import Jinja2Templates\n\n    tmpl_file = template_dir / \"test.html\"\n    tmpl_file.write_text(\"<div>{{ content }}</div>\")\n\n    # Create env with autoescape explicitly disabled\n    loader = jinja2.FileSystemLoader(str(template_dir))\n    env = jinja2.Environment(loader=loader, autoescape=False)\n\n    templates = Jinja2Templates(env=env)\n    template = templates.get_template(\"test.html\")\n    result = template.render({\"content\": \"<b>bold</b>\"})\n    # autoescape is disabled, so raw HTML should appear\n    assert \"<b>bold</b>\" in result\n\n\ndef test_autoescape_can_be_overridden(template_dir):\n    \"\"\"Caller can override autoescape when creating from directory.\"\"\"\n    from starlette.templating import Jinja2Templates\n\n    tmpl_file = template_dir / \"test.html\"\n    tmpl_file.write_text(\"<div>{{ content }}</div>\")\n\n    templates = Jinja2Templates(directory=str(template_dir), autoescape=False)\n    template = templates.get_template(\"test.html\")\n    result = template.render({\"content\": \"<b>bold</b>\"})\n    assert \"<b>bold</b>\" in result\n\n\ndef test_template_response_requires_request(template_dir):\n    \"\"\"TemplateResponse should raise if 'request' not in context.\"\"\"\n    from starlette.templating import Jinja2Templates\n\n    tmpl_file = template_dir / \"test.html\"\n    tmpl_file.write_text(\"Hello\")\n\n    templates = Jinja2Templates(directory=str(template_dir))\n    with pytest.raises(ValueError, match=\"request\"):\n        templates.TemplateResponse(\"test.html\", {})\n\n\ndef test_directory_required_without_env():\n    \"\"\"Should raise if neither directory nor env is provided.\"\"\"\n    from starlette.templating import Jinja2Templates\n\n    with pytest.raises(AssertionError):\n        Jinja2Templates()\n*** End Patch\n\nTask id: pr3166-session-middleware\n*** Begin Patch\n*** Add File: starlette/middleware/sessions.py\nimport json\nimport typing\nfrom base64 import b64decode, b64encode\n\nfrom itsdangerous import BadSignature, SignatureExpired, TimestampSigner\nfrom itsdangerous.exc import BadTimeSignature\n\n\nclass _SessionDict(dict):\n    \"\"\"\n    A dict subclass that tracks whether it has been modified.\n    \"\"\"\n\n    def __init__(self, *args: typing.Any, **kwargs: typing.Any) -> None:\n        super().__init__(*args, **kwargs)\n        self._modified = False\n        self._accessed = False\n\n    @property\n    def is_modified(self) -> bool:\n        return self._modified\n\n    @property\n    def is_accessed(self) -> bool:\n        return self._accessed\n\n    def __setitem__(self, key: typing.Any, value: typing.Any) -> None:\n        self._modified = True\n        self._accessed = True\n    ",
