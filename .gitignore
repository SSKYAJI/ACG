# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.env
.pytest_cache/
.ruff_cache/

# Node
node_modules/
dist/

# ACG outputs (working artifacts; the published chart lives in docs/benchmark.png)
# NOTE: `.acg/` is root-anchored so it doesn't blanket-exclude `demo-app/.acg/`
# (git's gitignore rules say a re-include like `!demo-app/.acg/foo.json` cannot
# resurrect a file if its *parent directory* is already excluded).
/.acg/
**/.acg/cache/
demo-app/.next/
demo-app/node_modules/
demo-app/.acg/*
# Allow the runtime trace + context graph to ship with the repo so the viz
# works from a fresh clone and the demo has a permanent artifact.
!demo-app/.acg/run_trace.json
!demo-app/.acg/context_graph.json

# Greenhouse experiment: the upstream Java repo is cloned at runtime.
experiments/greenhouse/checkout/
experiments/greenhouse/agent_lock.json
# Per-run eval artifacts. Promote individual files into docs/ when worth pinning.
experiments/greenhouse/runs/
# Real-repo experiments: each repo's checkout/ is cloned at runtime — never commit.
# Manifest entries + agent_lock + task definitions + run artifacts ARE tracked;
# only the upstream source tree (which is huge and not ours) is excluded.
experiments/real_repos/*/checkout/
experiments/realworld/checkout/
# Lock file used by compute_fail_to_pass.py for concurrent manifest writes.
experiments/real_repos/manifest.json.lock
experiments/real_repos/manifest.json.tmp
# .env backups created when reconfiguring LLM endpoint.
.env.bak.*
# Microservice benchmark upstream checkouts are cloned at runtime; keep only
# task definitions, lockfiles, and selected eval artifacts in-repo.
experiments/microservice/prisma-examples/
experiments/microservice/nestjs-boilerplate/
experiments/microservice/agent_lock.json
experiments/microservice/agent_lock_nest.json
experiments/microservice/tasks.json
experiments/microservice/tasks_nest.json
experiments/microservice/runs/
experiments/microservice/runs_nest/
# Devin probe traces contain session ids and may include bearer-token-flavored
# auth headers; never commit them.
scripts/diagnostics/devin_probe_output*.json

# Papers (personal / academic — not part of the project)
papers/

# Root-level PDFs and transient agent handoff / prompt files
/*.pdf
HANDOFF*.md
CODEX_*.md
PAPER_NUMBERS*.md

# OS
.DS_Store
