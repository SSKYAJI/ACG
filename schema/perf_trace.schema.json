{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acg.dev/schema/perf_trace/v1",
  "title": "ACG Perf Trace",
  "description": "Per-task runtime performance trace for baseline-vs-optimized GX10 demos.",
  "type": "object",
  "required": ["version", "generated_at", "lockfile", "config", "tasks", "global"],
  "properties": {
    "version": { "const": "1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "lockfile": { "type": "string" },
    "config": {
      "type": "object",
      "required": [
        "engine",
        "dtype",
        "parallel",
        "kv_cache_quant",
        "flash_attn",
        "worker_concurrency",
        "grace_overlap",
        "model_id",
        "model_sha"
      ],
      "properties": {
        "engine": { "type": "string" },
        "dtype": { "type": "string" },
        "parallel": { "type": "integer", "minimum": 0 },
        "kv_cache_quant": { "type": "string" },
        "flash_attn": { "type": "boolean" },
        "worker_concurrency": { "type": "integer", "minimum": 0 },
        "grace_overlap": { "type": "boolean" },
        "model_id": { "type": "string" },
        "model_sha": { "type": "string" }
      },
      "additionalProperties": true
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "group_id",
          "started_at",
          "completed_at",
          "wall_s",
          "first_token_s",
          "input_tokens",
          "output_tokens",
          "tokens_per_s_in",
          "tokens_per_s_out",
          "peak_gpu_mem_gib",
          "blackwell_sm_pct_avg",
          "grace_cpu_pct_avg"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "group_id": { "type": "integer", "minimum": 1 },
          "started_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" },
          "wall_s": { "type": "number", "minimum": 0 },
          "first_token_s": { "type": "number", "minimum": 0 },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "tokens_per_s_in": { "type": "number", "minimum": 0 },
          "tokens_per_s_out": { "type": "number", "minimum": 0 },
          "peak_gpu_mem_gib": { "type": "number", "minimum": 0 },
          "blackwell_sm_pct_avg": { "type": "number", "minimum": 0 },
          "grace_cpu_pct_avg": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "global": {
      "type": "object",
      "required": [
        "total_wall_s",
        "total_input_tokens",
        "total_output_tokens",
        "tokens_per_s_overall",
        "peak_gpu_mem_gib",
        "grace_cpu_pct_avg"
      ],
      "properties": {
        "total_wall_s": { "type": "number", "minimum": 0 },
        "total_input_tokens": { "type": "integer", "minimum": 0 },
        "total_output_tokens": { "type": "integer", "minimum": 0 },
        "tokens_per_s_overall": { "type": "number", "minimum": 0 },
        "peak_gpu_mem_gib": { "type": "number", "minimum": 0 },
        "grace_cpu_pct_avg": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
