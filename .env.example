# LLM endpoint — pick one

# ============================================
# Anthropic-direct (Claude Sonnet 4.6 / Opus 4.7)
# ============================================
# The harness uses an OpenAI-compatible client; Anthropic's /v1 endpoint
# accepts the same request shape. The API key goes in ACG_LLM_API_KEY.
#
# ACG_LLM_URL=https://api.anthropic.com/v1
# ACG_LLM_API_KEY=sk-ant-api03-...
# ACG_LLM_MODEL=claude-sonnet-4-6
#
# Note: Anthropic-direct does NOT return USD cost in the usage block —
# cost_usd_total, cost_usd_per_completed_task, acus_consumed_total will
# be NULL in eval_run_*.json. Compute cost externally:
#   $ = (tokens_prompt * 3 + tokens_completion * 15) / 1_000_000  # Sonnet 4.6

# Groq free tier (recommended for development)
ACG_LLM_URL=https://api.groq.com/openai/v1
ACG_LLM_MODEL=llama-3.3-70b-versatile
ACG_LLM_API_KEY=your_groq_key_here

# vLLM on ASUS GX10 (demo / privacy-sensitive deployments)
# ACG_LLM_URL=http://localhost:8000/v1
# ACG_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
# ACG_LLM_API_KEY=anything

# Offline / CI fallback (returns canned predictions for the demo task set)
# ACG_MOCK_LLM=1

# Compile-time model override (predictor: seed expansion + rerank + scope review).
# These calls only need structured JSON output, NOT frontier thinking — running
# the compile through a fast cheap coder model gives ~5x speedup + ~10x cost cut
# without measurable quality loss. Runtime (orchestrator/workers) still uses
# the ACG_LLM_* settings above.
# ACG_COMPILE_MODEL=qwen/qwen3-coder-30b-a3b-instruct
# ACG_COMPILE_URL=https://openrouter.ai/api/v1   # falls back to ACG_LLM_URL
# ACG_COMPILE_API_KEY=...                        # falls back to ACG_LLM_API_KEY
# ACG_COMPILE_TASK_CONCURRENCY=3   # default 3; parallel predictor calls per task. Lower for tight rate limits.

# Runtime (acg run / Greenhouse local): omit ACG_SUB_MAX_TOKENS / ACG_ORCH_MAX_TOKENS
# or set to 0/none to omit max_tokens from API payloads (provider-native budget).
# Leave ACG_WORKER_MAX_TOKENS / ACG_SUB_MAX_TOKENS unset for provider native max;
# setting above the model's hard ceiling returns 400.
# ACG_REQUEST_TIMEOUT_S=900
# ACG_WORKER_MAX_TOKENS=8192  # worker max_tokens when ACG_SUB_MAX_TOKENS is unset (default 4096)
# ACG_WORKER_CONCURRENCY=0   # Greenhouse harness: 0/unset = uncapped parallel workers
# ACG_APPLIED_BRANCH_CLEANUP=1  # delete acg-applied/* branches after applied-diff capture

# Devin v3 API (live `devin-api` backend in the Greenhouse harness).
# Get the token from your Devin org settings — it must start with `cog_`.
# Org id is visible in the URL of any Devin session detail page.
# DEVIN_API_KEY=cog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEVIN_ORG_ID=org-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override for self-hosted enterprise tenants.
# DEVIN_API_BASE_URL=https://api.devin.ai
