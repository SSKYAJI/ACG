# LLM endpoint — pick one

# Groq free tier (recommended for development)
ACG_LLM_URL=https://api.groq.com/openai/v1
ACG_LLM_MODEL=llama-3.3-70b-versatile
ACG_LLM_API_KEY=your_groq_key_here

# vLLM on ASUS GX10 (demo / privacy-sensitive deployments)
# ACG_LLM_URL=http://localhost:8000/v1
# ACG_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
# ACG_LLM_API_KEY=anything

# Offline / CI fallback (returns canned predictions for the demo task set)
# ACG_MOCK_LLM=1

# Devin v3 API (live `devin-api` backend in the Greenhouse harness).
# Get the token from your Devin org settings — it must start with `cog_`.
# Org id is visible in the URL of any Devin session detail page.
# DEVIN_API_KEY=cog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEVIN_ORG_ID=org-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override for self-hosted enterprise tenants.
# DEVIN_API_BASE_URL=https://api.devin.ai
